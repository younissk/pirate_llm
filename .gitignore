# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# ---- Env / secrets ----
.env
.env.*
!example.env

# ---- OS ----
.DS_Store

# ---- Project artifacts ----
out/
wandb/
runs/
*.pt
*.bin
*.safetensors

# Materialized source corpora (arrow shards) — rebuild via
# `python -m nanobeard.dataset_pipeline.sources --source <name>`.
# Ignore each source's contents but NOT the dir, so source.json can be kept
# (git can't re-include a file whose parent dir is excluded).
data/sources/*/*
# ...but keep each source's provenance manifest.
!data/sources/*/source.json

# Tokenizers + recipes + metadata are small text — version them.
# (train.bin/val.bin are already covered by *.bin above.)
!data/**/pirate_bpe.json
!pirate_bpe.json

# ---- Space staging copies (generated by scripts/publish_space.py) ----
space/nanobeard/
space/assets/

# ---- HF release staging dir (generated by scripts/publish_hf.py) ----
hf_release/

# ---- IDE ----
.idea/
.vscode/

# ---- mkdocs build output ----
site/

# ---- vast.ai state ----
.vast_instance
.vast_instance_*

# ---- local Claude Code agent state ----
.claude/

# ---- llm-chess eval caches (regenerable; re-run the arena) ----
evals/llm-chess/results/*_cache.jsonl

# ONNX export artifacts for the mobile app (uploaded to HF, not source)
export/
